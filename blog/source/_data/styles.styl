// 展开收起效果
.highlight-container
  position: relative
  background-color: highlight-background
  &.on
    .highlight-footer
      display: none
    .hide-btn
      display: flex
    .highlight-wrap
      max-height: none
  .highlight-wrap
    overflow: hidden
    max-height: 200px
  .highlight-footer
    position absolute
    width: 100%
    left: 0
    bottom: 0
    height: 60px
    background-image: 'linear-gradient(-180deg, rgba(255,255,255,0) 0%, %s 65%)' % highlight-background;
    text-align: center
  .show-btn
    font-size: 12px
    color: #fff
    position: absolute
    left: 50%
    transform: translateX(-50%)
    bottom: 0
    line-height: 2em
    text-decoration: none
    padding: 0 0.8em
    text-align: center
    border-radius: 4px 4px 0
    &:hover
      text-decoration: none
  .hide-btn
    color: #fff
    font-size: 12px
    width: 22px
    position: absolute
    left: -21px
    top: 0
    line-height: 1em
    text-decoration: none
    text-align: center
    display: none
    flex-direction: column
    background-color: highlight-background
    border-radius: 4px 0 0 4px
    padding: 0.1em 0 0.6em
    transition: top ease 0.35s
  .fa-angle-up,
  .fa-angle-down
    font-style: normal
    color: #fff
  .fa-angle-up:before
    content:"\f106"
  .fa-angle-down:before
    content:"\f107"
    margin-left: 0.5em
  .js_unfold_code_btn, .js_retract_code_btn
    background: rgba(0,0,0,0.5)
    border-bottom: none !important
    &:hover
      border-bottom-color: none !important

// 为文章正文中的搜索关键词高亮添加自定义样式
// 让文章正文的高亮效果与搜索弹窗中的效果保持完全一致
.post-body .search-keyword
  color: rgb(255, 42, 42)
  font-weight: bold
  border-bottom: 1px dashed rgb(255, 42, 42)

.post-body .search-keyword-current
  background: rgba(255, 214, 64, 0.35)
  border-bottom-color: #ffb300
  border-radius: 2px

.post-body a[target='_blank']:not(.fancybox)::after
  content: "\f35d"
  display: inline-block
  font-family: "Font Awesome 5 Free"
  font-size: 0.72em
  font-weight: 900
  margin-left: 0.25em
  opacity: 0.65
  transform: translateY(-0.08em)

.post-body a[target='_blank']:has(img)::after
  display: none

.persistent-search-trigger
  align-items: center
  background: var(--card-bg-color)
  border: 0
  border-radius: 4px
  box-shadow: $box-shadow
  color: var(--text-color)
  cursor: pointer
  display: flex
  font-size: 14px
  gap: 6px
  line-height: 1
  padding: 10px 12px
  position: fixed
  right: 24px
  transition: color .2s, transform .2s
  z-index: $zindex-3

  &:hover
    color: var(--link-hover-color)
    transform: translateY(-1px)

.persistent-search-trigger-mobile
  bottom: 72px
  display: none
  position: fixed
  right: 24px

.menu-item-search-fixed
  background: var(--content-bg-color)
  box-shadow: $box-shadow
  left: var(--search-fixed-left)
  margin: 0
  position: fixed
  top: 12px
  width: var(--search-fixed-width)
  z-index: $zindex-3

  a
    background: var(--menu-item-bg-color)

.search-menu-fixed
  .sidebar-inner.affix
    top: 64px

.search-hit-nav
  align-items: center
  background: var(--card-bg-color)
  border-radius: 4px
  bottom: 24px
  box-shadow: $box-shadow
  color: var(--text-color)
  display: flex
  gap: 8px
  padding: 8px
  position: fixed
  right: 24px
  z-index: $zindex-3

  button
    background: transparent
    border: 0
    color: inherit
    cursor: pointer
    font-size: 18px
    line-height: 1
    min-width: 24px
    padding: 2px 4px

    &:hover
      color: var(--link-hover-color)

.search-hit-count
  color: $grey-dark
  font-size: 12px
  min-width: 42px
  text-align: center

.search-result-list
  li > a
    display: block

.search-history
  display: flex
  flex-wrap: wrap
  gap: 6px
  padding: 0 10px 10px 42px

  &.search-history-empty
    display: none

.search-history-item
  background: var(--body-bg-color)
  border: 0
  border-radius: 4px
  color: $grey-dark
  cursor: pointer
  font-size: $font-size-smaller
  line-height: 1.4
  max-width: 160px
  overflow: hidden
  padding: 3px 7px
  text-overflow: ellipsis
  white-space: nowrap

  &:hover
    color: var(--link-hover-color)

.right-posts-card
  background: var(--content-bg-color)
  border-radius: $border-radius
  box-shadow: $box-shadow
  font-size: $font-size-smaller
  padding: 12px 10px
  position: fixed
  right: 24px
  text-align: left
  top: 112px
  width: 220px
  z-index: $zindex-1

.right-posts-title
  border-bottom: 1px dotted $grey-light
  color: var(--text-color)
  font-size: $font-size-small
  font-weight: 600
  margin: 0 0 8px
  padding-bottom: 8px
  text-align: center

.right-posts-list
  list-style: none
  margin: 0
  max-height: calc(100vh - 190px)
  overflow-y: auto
  padding: 0

.right-posts-item
  line-height: 1.45
  margin: 0

  a
    border-bottom: 0
    color: $grey-dark
    display: block
    overflow: hidden
    padding: 4px 6px
    text-overflow: ellipsis
    white-space: nowrap

    &:hover
      background: var(--body-bg-color)
      border-bottom: 0
      border-radius: 4px
      color: var(--link-hover-color)

.right-posts-item-active
  a
    background: var(--body-bg-color)
    border-radius: 4px
    color: var(--link-hover-color)

@media (min-width: 1501px) and (max-width: 1700px)
  .main-inner
    transform: translateX(-120px)

@media (max-width: 1500px)
  .right-posts-card
    display: none

+tablet-mobile()
  .persistent-search-trigger
    border-radius: 0
    bottom: 68px
    padding: 6px

    span
      display: none

  .persistent-search-trigger-mobile
    display: flex
    right: 20px

  .search-hit-nav
    bottom: 106px
    right: 14px
    padding: 8px 10px

// 首页文章列表更紧凑
.index.posts-expand
  background: var(--content-bg-color)
  border-radius: $border-radius-inner
  box-shadow: $box-shadow-inner
  padding: 16px 28px 4px

  .post-block
    background: transparent
    border-bottom: 1px solid var(--body-bg-color)
    border-radius: 0
    box-shadow: none
    padding: 16px 0 14px

    & + .post-block
      margin-top: 0

    &:last-of-type
      border-bottom: 0

  .post-header
    margin-bottom: 6px
    text-align: left

  .post-title
    font-size: 1.22em
    line-height: 1.35
    margin: 0
    text-align: left

  .post-meta
    margin: 5px 0 0
    line-height: 1.7
    text-align: left

    br
      display: none

  .post-meta-item
    display: inline-block
    margin-right: 1em

  .post-body
    color: $grey-dark
    font-size: $font-size-small
    line-height: 1.7
    margin-top: 6px

    > :first-child
      margin-top: 0

    > :last-child
      margin-bottom: 0

  .post-button
    margin-top: 8px

  .post-footer
    display: none

+tablet-mobile()
  .index.posts-expand
    padding: 6px 18px 2px

    .post-block
      padding: 14px 0 12px

    .post-title
      font-size: 1.12em
