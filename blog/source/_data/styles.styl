// 展开收起效果
.highlight-container
  position: relative
  background-color: highlight-background
  &.on
    .highlight-footer
      display: none
    .hide-btn
      display: flex
    .highlight-wrap
      max-height: none
  .highlight-wrap
    overflow: hidden
    max-height: 200px
  .highlight-footer
    position absolute
    width: 100%
    left: 0
    bottom: 0
    height: 60px
    background-image: 'linear-gradient(-180deg, rgba(255,255,255,0) 0%, %s 65%)' % highlight-background;
    text-align: center
  .show-btn
    font-size: 12px
    color: #fff
    position: absolute
    left: 50%
    transform: translateX(-50%)
    bottom: 0
    line-height: 2em
    text-decoration: none
    padding: 0 0.8em
    text-align: center
    border-radius: 4px 4px 0
    &:hover
      text-decoration: none
  .hide-btn
    color: #fff
    font-size: 12px
    width: 22px
    position: absolute
    left: -21px
    top: 0
    line-height: 1em
    text-decoration: none
    text-align: center
    display: none
    flex-direction: column
    background-color: highlight-background
    border-radius: 4px 0 0 4px
    padding: 0.1em 0 0.6em
    transition: top ease 0.35s
  .fa-angle-up,
  .fa-angle-down
    font-style: normal
    color: #fff
  .fa-angle-up:before
    content:"\f106"
  .fa-angle-down:before
    content:"\f107"
    margin-left: 0.5em
  .js_unfold_code_btn, .js_retract_code_btn
    background: rgba(0,0,0,0.5)
    border-bottom: none !important
    &:hover
      border-bottom-color: none !important

// 为文章正文中的搜索关键词高亮添加自定义样式
// 让文章正文的高亮效果与搜索弹窗中的效果保持完全一致
.post-body .search-keyword
  color: rgb(255, 42, 42)
  font-weight: bold
  border-bottom: 1px dashed rgb(255, 42, 42)

// 首页文章列表更紧凑
.index.posts-expand
  background: var(--content-bg-color)
  border-radius: $border-radius-inner
  box-shadow: $box-shadow-inner
  padding: 16px 28px 4px

  .post-block
    background: transparent
    border-bottom: 1px solid var(--body-bg-color)
    border-radius: 0
    box-shadow: none
    padding: 16px 0 14px

    & + .post-block
      margin-top: 0

    &:last-of-type
      border-bottom: 0

  .post-header
    margin-bottom: 6px
    text-align: left

  .post-title
    font-size: 1.22em
    line-height: 1.35
    margin: 0
    text-align: left

  .post-meta
    margin: 5px 0 0
    line-height: 1.7
    text-align: left

    br
      display: none

  .post-meta-item
    display: inline-block
    margin-right: 1em

  .post-body
    color: $grey-dark
    font-size: $font-size-small
    line-height: 1.7
    margin-top: 6px

    > :first-child
      margin-top: 0

    > :last-child
      margin-bottom: 0

  .post-button
    margin-top: 8px

  .post-footer
    display: none

+tablet-mobile()
  .index.posts-expand
    padding: 6px 18px 2px

    .post-block
      padding: 14px 0 12px

    .post-title
      font-size: 1.12em
